{
  "name": "h5-game-tool-components",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "adapt:crimsondesert": "node scripts/adapt-crimsondesert.mjs",
    "generate:map-page": "node scripts/generate-map-page.mjs",
    "build:map-h5": "node scripts/build-map-h5.mjs",
    "build:crimsondesert-h5": "node scripts/build-map-h5.mjs --package public/data/crimsondesert",
    "validate:skill-pack": "node scripts/validate-skill-pack.mjs",
    "validate:wiki-template": "node scripts/validate-wiki-home-template.mjs",
    "validate:wiki-home-template": "node scripts/validate-wiki-home-template.mjs",
    "validate:map": "node scripts/validate-map-package.mjs",
    "validate:crimsondesert": "node scripts/validate-map-package.mjs --package public/data/crimsondesert",
    "generate:map-output": "node scripts/generate-map-output.mjs",
    "generate:crimsondesert-output": "node scripts/generate-map-output.mjs --package public/data/crimsondesert --output public/data/crimsondesert/page.output.json"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remixicon": "^4.9.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  }
}
