{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.game-h5-tool/datasource-schema/map.meta.schema.json",
  "title": "Map Metadata Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "game",
    "maps",
    "assets",
    "uiRules"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "game": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "logo": {
          "type": "string"
        }
      }
    },
    "maps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/map"
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "iconBase",
        "imageBase"
      ],
      "properties": {
        "iconBase": {
          "type": "string"
        },
        "imageBase": {
          "type": "string"
        }
      }
    },
    "uiRules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "singleMapSelect",
        "detailFallback",
        "areaDisplay"
      ],
      "properties": {
        "singleMapSelect": {
          "type": "string",
          "enum": [
            "disabled",
            "hidden"
          ]
        },
        "detailFallback": {
          "type": "string",
          "enum": [
            "show-title-only"
          ]
        },
        "areaDisplay": {
          "type": "string",
          "enum": [
            "center-label",
            "none"
          ]
        }
      }
    }
  },
  "$defs": {
    "map": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "tile",
        "coordinate"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "default": {
          "type": "boolean"
        },
        "tile": {
          "oneOf": [
            {
              "$ref": "#/$defs/templateTile"
            },
            {
              "$ref": "#/$defs/manifestTile"
            }
          ]
        },
        "coordinate": {
          "$ref": "#/$defs/coordinate"
        }
      }
    },
    "baseTile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceType",
        "tileSize",
        "imageType",
        "minZoom",
        "maxZoom",
        "maxNativeZoom",
        "tileOrigin",
        "indexOrder"
      ],
      "properties": {
        "sourceType": {
          "type": "string",
          "enum": [
            "template",
            "manifest"
          ]
        },
        "tileSize": {
          "type": "integer",
          "minimum": 1
        },
        "imageType": {
          "type": "string",
          "enum": [
            "png",
            "jpg",
            "jpeg",
            "webp"
          ]
        },
        "minZoom": {
          "type": "integer",
          "minimum": 0
        },
        "maxZoom": {
          "type": "integer",
          "minimum": 0
        },
        "maxNativeZoom": {
          "type": "integer",
          "minimum": 0
        },
        "tileOrigin": {
          "type": "string",
          "enum": [
            "top-left"
          ]
        },
        "indexOrder": {
          "type": "string",
          "enum": [
            "z-x-y"
          ]
        }
      }
    },
    "templateTile": {
      "allOf": [
        {
          "$ref": "#/$defs/baseTile"
        },
        {
          "type": "object",
          "required": [
            "sourceType",
            "urlTemplate"
          ],
          "properties": {
            "sourceType": {
              "const": "template"
            },
            "urlTemplate": {
              "type": "string",
              "minLength": 1,
              "pattern": "\\{z\\}.*\\{x\\}.*\\{y\\}|\\{z\\}.*\\{y\\}.*\\{x\\}|\\{x\\}.*\\{z\\}.*\\{y\\}|\\{x\\}.*\\{y\\}.*\\{z\\}|\\{y\\}.*\\{z\\}.*\\{x\\}|\\{y\\}.*\\{x\\}.*\\{z\\}"
            }
          }
        }
      ]
    },
    "manifestTile": {
      "allOf": [
        {
          "$ref": "#/$defs/baseTile"
        },
        {
          "type": "object",
          "required": [
            "sourceType",
            "manifest"
          ],
          "properties": {
            "sourceType": {
              "const": "manifest"
            },
            "manifest": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "coordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin",
        "axis",
        "width",
        "height",
        "projectZoom"
      ],
      "properties": {
        "origin": {
          "type": "string",
          "enum": [
            "top-left"
          ]
        },
        "axis": {
          "type": "string",
          "enum": [
            "x-right-y-down"
          ]
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "projectZoom": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
