{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.game-h5-tool/datasource-schema/tile-manifest.schema.json",
  "title": "Tile Manifest Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "tiles"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "tiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "z",
          "x",
          "y",
          "src"
        ],
        "properties": {
          "z": {
            "type": "integer",
            "minimum": 0
          },
          "x": {
            "type": "integer",
            "minimum": 0
          },
          "y": {
            "type": "integer",
            "minimum": 0
          },
          "src": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
