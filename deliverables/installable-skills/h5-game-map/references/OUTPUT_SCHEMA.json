{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.game-h5-tool/OUTPUT_SCHEMA.json",
  "title": "Game H5 Tool AI Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "toolType",
    "templateId",
    "pageMeta",
    "regions",
    "assets",
    "warnings"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "toolType": {
      "type": "string",
      "enum": [
        "map",
        "wiki",
        "guide-config"
      ]
    },
    "templateId": {
      "type": "string"
    },
    "pageMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "sourceStatus": {
          "type": "string",
          "enum": [
            "bound-to-datasource",
            "TODO_FROM_DATASOURCE"
          ]
        }
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/region"
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/asset"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "components"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/componentInstance"
          }
        }
      }
    },
    "componentInstance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "componentId",
        "props"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "componentId": {
          "type": "string"
        },
        "props": {
          "oneOf": [
            {
              "type": "object"
            },
            {
              "type": "string",
              "const": "TODO_FROM_DATASOURCE"
            }
          ]
        },
        "dataBinding": {
          "oneOf": [
            {
              "type": "object"
            },
            {
              "type": "string",
              "const": "TODO_FROM_DATASOURCE"
            }
          ]
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "source": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "string",
              "const": "TODO_FROM_DATASOURCE"
            }
          ]
        }
      }
    }
  }
}

