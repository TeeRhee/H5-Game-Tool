{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.game-h5-tool/schemas/template.schema.json",
  "title": "Template Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "displayName",
    "source",
    "status",
    "viewport",
    "regions",
    "requiredRendererBehavior"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer"
    },
    "id": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "source": {
      "type": "object"
    },
    "status": {
      "type": "string"
    },
    "viewport": {
      "type": "object"
    },
    "regions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/region"
      }
    },
    "requiredRendererBehavior": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "purpose",
        "allowedComponents",
        "dataRequirement"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "allowedComponents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pendingDataBoundElements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "layout": {
          "type": "object"
        },
        "dataRequirement": {
          "type": "string"
        }
      }
    }
  }
}
