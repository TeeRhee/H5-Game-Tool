{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.game-h5-tool/schemas/tool-types.schema.json",
  "title": "Tool Types Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "toolTypes"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer"
    },
    "toolTypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/toolType"
      }
    }
  },
  "$defs": {
    "toolType": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "status",
        "description",
        "template",
        "componentRegistry",
        "datasourceSchema",
        "mapping",
        "examples",
        "classificationSignals"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "template": {
          "type": "string"
        },
        "componentRegistry": {
          "type": "string"
        },
        "datasourceSchema": {
          "type": "string"
        },
        "mapping": {
          "type": "string"
        },
        "examples": {
          "type": "string"
        },
        "classificationSignals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}

