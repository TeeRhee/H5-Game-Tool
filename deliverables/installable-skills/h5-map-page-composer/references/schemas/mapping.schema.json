{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.game-h5-tool/schemas/mapping.schema.json",
  "title": "Map Field Mapping Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "toolType",
    "status",
    "inputPackage",
    "outputSchema",
    "rules",
    "fieldMappings",
    "regionMappings"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "toolType": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "inputPackage": {
      "type": "object"
    },
    "outputSchema": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fieldMappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "target",
          "required"
        ],
        "properties": {
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "regionMappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "regionId",
          "components"
        ],
        "properties": {
          "regionId": {
            "type": "string"
          },
          "components": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
